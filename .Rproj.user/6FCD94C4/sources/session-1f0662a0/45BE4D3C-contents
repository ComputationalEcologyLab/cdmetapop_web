# Read in master patch file for reference needed to get the total number of stocked YY per year (number_released)
##############################################################
patch_master_path <- '~/Documents/UM_backup/CDMetaPop/EBT/EBT_Inputs/benchmark_testing/limited/patchvars/PatchEBT415_master.csv'
tmp <- separate_column(patch_master_path, "N0", sep = "|")
tmp_patch <- data.frame(
  colname = colnames(tmp)[5:dim(tmp)[2]],
  number_released = colSums(tmp[, 5:dim(tmp)[2]], na.rm = TRUE),
  year = c(23:119)
)
