# Set working directory for scenario 1
parent_dir <- '~/Documents/UM_backup/CDMetaPop/EBT/EBT_Inputs/benchmark_testing/limited/output_master_modified1763682572'

dirs <- list.dirs(path = parent_dir, full.names = TRUE, recursive = FALSE)

# Step 1: Read and calculate calculate average size of fish for each directory
 
# Loop over those directories and find 'ind<number>.csv' inside
results <- map_dfr(dirs, function(dir) {
  # Extract mc number from directory path
  mc_number <- str_extract(dir, "(?<=mc)\\d+")
  
  # List 'ind*.csv' files inside this directory
  ind_files <- list.files(path = dir, pattern = "^ind\\d+\\.csv$", full.names = TRUE)
  
  # For each ind file, compute the average size of fish by age and sex
  map_dfr(ind_files, function(file_path) {
    # Extract ind number from filename
    ind_number <- str_extract(basename(file_path), "\\d+")
    
    # Read the CSV
    df <- read.csv(file_path, stringsAsFactors = FALSE)
    
    df %>%
      group_by(age, sex) %>%
      summarise(
        size = {
          m <- mean(size, na.rm = TRUE)
          if (is.nan(m)) NA_real_ else m
        },
        count = n(),
        .groups = "drop"
      ) %>%
      mutate(
        mc  = as.integer(mc_number),
        ind = as.integer(ind_number)
      )
  })
})

# Step 2: group all age 7+ together as age 7
results <- results %>%
  mutate(age = ifelse(age >= 7, 7, age))


# Step 3: report the mean size and sd by age 1 and 2
df_summary <- results %>%
  #filter(age == 1 | age == 2) %>%
  group_by(age, sex) %>%
  summarise(
    mean_size = mean(size, na.rm = TRUE),
    mean_count = mean(count, na.rm = TRUE),
    sd_count = sd(count, na.rm = TRUE),
    sd_size   = sd(size, na.rm = TRUE)
  )

