# Initialize list to store results

upper_sexratio_list <- list()

# Iterate once through all files
walk(target_dirs, function(dir_path) {
  mc_number <- str_extract(dir_path, "(?<=mc)\\d+")
  ind_files <- list.files(path = dir_path, pattern = "^ind\\d+\\.csv$", full.names = TRUE)
  
  walk(ind_files, function(file_path) {
    ind_number <- str_extract(basename(file_path), "\\d+")
    df <- read.csv(file_path, stringsAsFactors = FALSE)
    df <- df %>% left_join(patches, by = "PatchID", relationship = "many-to-many")
    
    # calculation: proportion of YOY xy over total wild
    upper_sexratio_df <- df %>%
      filter(sex != "MYY", sullivan == "upper") %>%
      group_by(sullivan, age) %>%
      summarise(
        proportion_XYmales = mean(sex == "MXY", na.rm = TRUE),
        .groups = "drop"
      ) %>%
      mutate(
        mc = as.integer(mc_number),
        ind = as.integer(ind_number)
      )
    
    # Append to list
    
    upper_sexratio_list <<- append(upper_sexratio_list, list(upper_sexratio_df))
  })
})

# Combine into final data frame
upper_sexratio_results <- bind_rows(upper_sexratio_list)

# Create table with results 
upper <- upper_sexratio_results %>%
  filter(age != 1, between(ind, 24, 28)) %>%
  group_by(ind) %>%
  summarise(
    avg_male = mean(proportion_XYmales, na.rm = TRUE)
  )




