library(dplyr)
library(tidyr)
library(purrr)
library(stringr)
library(ggplot2)

# empirical sex-ratio in sullivan headwaters 
# Set working directory for scenario 1
parent_dir <- '~/Documents/UM_backup/CDMetaPop/EBT/EBT_Inputs/benchmark_testing/limited/output_master_modified1763682572'
# Get all subdirectories
target_dirs <- list.dirs(path = parent_dir, full.names = TRUE, recursive = FALSE)

patches <- read.csv("~/Documents/UM_backup/UtilityFiles/sullivan_patches_409.csv")
empirical <- data.frame(Year = c(2020:2024), 
                        ind = c(24:28),
                        #myy_ancestry_upper = c(0.13, 0.20, 0.18, 0.50, 0.49), 
                        #myy_ancestry_middle = c(0.08, 0.02, 0.12,0.14,0.26), 
                        male_percent_upper = c(0.53, 0.58, 0.54, 0.76, 0.73),
                        male_percent_middle = c(0.53, 0.47, 0.60, 0.56, 0.62))

# Initialize list to store results

sexratio_list <- list()

# Iterate once through all files
walk(target_dirs, function(dir_path) {
  mc_number <- str_extract(dir_path, "(?<=mc)\\d+")
  ind_files <- list.files(path = dir_path, pattern = "^ind\\d+\\.csv$", full.names = TRUE)
  
  walk(ind_files, function(file_path) {
    ind_number <- str_extract(basename(file_path), "\\d+")
    df <- read.csv(file_path, stringsAsFactors = FALSE)
    df <- df %>% left_join(patches, by = "PatchID", relationship = "many-to-many")
    
    # Focus upper sullivan  
    df_filtered <- df %>%
      filter(sullivan == "upper")
    
    # calculation: proportion of YOY xy over total wild
    sexratio_df <- df_filtered %>%
      filter(sex != "MYY", age == 1) %>%
      summarise(
        proportion_XYmales = mean(sex == "MXY", na.rm = TRUE),
        .groups = "drop"
      ) %>%
      mutate(
        mc = as.integer(mc_number),
        ind = as.integer(ind_number)
      )

    # Append to list
  
    sexratio_list <<- append(sexratio_list, list(sexratio_df))
  })
})

# Combine into final data frames
sexratio_results <- bind_rows(sexratio_list)

# Create table with results - comparing empirical and simulated
simulation <- sexratio_results %>%
  group_by(ind) %>%
  summarise(avg_male = mean(proportion_XYmales, na.rm = TRUE),
            .groups = "drop")

# Join by 'ind'
combined <- left_join(empirical, simulation[c(25:29),], by = "ind")

# Plot results
ggplot() +
  # Layer 1: simulation results of proportion of at least 25% YY genes
  geom_point(data = sexratio_results, 
             aes(x = ind, y = proportion_XYmales), 
             size = 1, alpha = 0.5) +

  geom_point(data = empirical,
             aes(x = ind, y = male_percent_upper),
             color = "tomato",
             alpha = 0.4,
             size = 2) +
  
  geom_line(data = empirical, 
            aes(x = ind, y = male_percent_upper), color = "tomato", linetype = "dashed") +
  
  scale_x_continuous(limits = c(0, 50)) +
  
  labs(x = "Year", y = "XY proportion", title = "Proportion of YOY XY males Sims vs Empirical (Upper Sullivan)") +
  theme_minimal() +
  theme(legend.position = "none")

# Save combined results to CSV
write.csv(combined, file = "mxy_simulated_empirical_upper_sull.csv", row.names = FALSE)
# Save plots
ggsave("mxy_simulated_empirical_upper_sull.pdf", width = 10, height = 6)
